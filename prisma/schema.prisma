// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/prisma-client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Enums
enum Role {
  owner
  admin
  doctor
  staff
  receptionist
}

enum SubscriptionPlan {
  free
  basic
  premium
  enterprise
}

enum AppointmentStatus {
  scheduled
  confirmation_pending
  confirmed
  in_progress
  completed
  cancelled
  no_show
  rescheduled
}

enum Channel {
  web
  whatsapp
  sms
  email
}

enum SenderType {
  patient
  clinic
  system
}

enum MessageType {
  text
  image
  file
  template
}

enum MessageStatus {
  sent
  delivered
  read
  failed
}

enum ReminderType {
  email
  sms
  whatsapp
  push
}

enum ReminderStatus {
  pending
  sent
  failed
  cancelled
}

enum NotificationJobStatus {
  pending
  queued
  sent
  failed
}

enum CampaignType {
  announcement
  reminder
  promotion
  follow_up
}

enum CampaignStatus {
  draft
  scheduled
  running
  completed
  cancelled
}

enum Severity {
  info
  warning
  error
  critical
}

enum EntityType {
  appointment
  patient
  conversation
  system
}

// Models
model Clinic {
  id                    String           @id @default(cuid())
  name                  String
  slug                  String           @unique
  address               String?
  phone                 String?
  email                 String?          @unique
  website               String?
  timezone              String           @default("UTC")
  isActive              Boolean          @default(true)
  subscriptionPlan      SubscriptionPlan @default(free)
  subscriptionExpiresAt DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  // Relations
  memberships    Membership[]
  doctors        Doctor[]
  services       Service[]
  patients       Patient[]
  appointments   Appointment[]
  conversations  Conversation[]
  reminders      Reminder[]
  notificationJobs NotificationJob[]
  campaigns      Campaign[]
  clinicSettings ClinicSettings?
  businessHours  BusinessHours[]
  escalationLogs EscalationLog[]

  @@map("clinics")
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String
  firstName       String?
  lastName        String?
  phone           String?
  isEmailVerified Boolean   @default(false)
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  invitedMemberships    Membership[]    @relation("MembershipInviter")
  assignedConversations Conversation[]
  sentMessages          Message[]
  memberships           Membership[]
  doctors               Doctor[]
  appointments          Appointment[]
  campaigns             Campaign[]
  escalationLogs        EscalationLog[]

  @@map("users")
}

model Membership {
  id        String    @id @default(cuid())
  userId    String
  clinicId  String
  role      Role      @default(staff)
  isActive  Boolean   @default(true)
  invitedBy String?
  invitedAt DateTime?
  joinedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinic  Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  inviter User?  @relation("MembershipInviter", fields: [invitedBy], references: [id])

  @@unique([userId, clinicId])
  @@map("memberships")
}

model Doctor {
  id            String   @id @default(cuid())
  clinicId      String
  userId        String?
  firstName     String
  lastName      String
  email         String?
  phone         String?
  specialty     String?
  licenseNumber String?
  availabilitySchedule Json? @map("availability_schedule")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  clinic       Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  user         User?         @relation(fields: [userId], references: [id])
  appointments Appointment[]

  @@map("doctors")
}

model Service {
  id              String   @id @default(cuid())
  clinicId        String
  name            String
  description     String?
  durationMinutes Int
  price           Float?
  category        String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  clinic       Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@map("services")
}

model Patient {
  id                    String    @id @default(cuid())
  clinicId              String
  firstName             String
  lastName              String
  email                 String?
  phone                 String?
  dateOfBirth           DateTime?
  address               String?
  emergencyContactName  String?
  emergencyContactPhone String?
  medicalHistory        String?
  allergies             String?
  notes                 String?
  lastVisitAt           DateTime?
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  clinic        Clinic         @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments  Appointment[]
  conversations Conversation[]
  notificationJobs NotificationJob[]

  @@map("patients")
}

model Appointment {
  id                 String            @id @default(cuid())
  clinicId           String
  patientId          String
  doctorId           String
  serviceId          String
  scheduledAt        DateTime
  durationMinutes    Int
  status             AppointmentStatus @default(scheduled)
  confirmationRequestedAt DateTime?
  confirmedAt        DateTime?
  reminder24hSentAt  DateTime?
  reminder3hSentAt   DateTime?
  lastReminderType   String?
  lastPatientMessageAt DateTime?
  notes              String?
  cancellationReason String?
  rescheduledFromId  String?
  createdBy          String
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  // Relations
  clinic          Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient         Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor          Doctor        @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  service         Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  creator         User          @relation(fields: [createdBy], references: [id])
  rescheduledFrom Appointment?  @relation("AppointmentReschedule", fields: [rescheduledFromId], references: [id])
  rescheduledTo   Appointment[] @relation("AppointmentReschedule")
  reminders       Reminder[]
  notificationJobs NotificationJob[]

  @@map("appointments")
}

model Conversation {
  id            String    @id @default(cuid())
  clinicId      String
  patientId     String
  channel       Channel   @default(web)
  externalId    String?
  isActive      Boolean   @default(true)
  lastMessageAt DateTime?
  assignedTo    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  clinic   Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient  Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  assignee User?     @relation(fields: [assignedTo], references: [id])
  messages Message[]

  @@map("conversations")
}

model Message {
  id             String        @id @default(cuid())
  conversationId String
  senderType     SenderType
  senderId       String?
  content        String
  messageType    MessageType   @default(text)
  externalId     String?       @unique
  status         MessageStatus @default(sent)
  sentAt         DateTime?
  deliveredAt    DateTime?
  readAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User?        @relation(fields: [senderId], references: [id])

  @@map("messages")
}

model Reminder {
  id            String         @id @default(cuid())
  clinicId      String
  appointmentId String
  type          ReminderType
  scheduledAt   DateTime
  sentAt        DateTime?
  status        ReminderStatus @default(pending)
  template      String?
  customMessage String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // Relations
  clinic      Clinic      @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  notificationJobs NotificationJob[]

  @@unique([appointmentId, type, scheduledAt])
  @@map("reminders")
}

model NotificationJob {
  id                String                @id @default(cuid())
  clinicId          String
  reminderId        String
  appointmentId     String
  patientId         String
  channel           Channel
  destination       String
  messageBody       String
  provider          String?
  providerMessageId String?
  status            NotificationJobStatus @default(pending)
  errorMessage      String?
  scheduledFor      DateTime
  sentAt            DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  clinic      Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  reminder    Reminder     @relation(fields: [reminderId], references: [id], onDelete: Cascade)
  appointment Appointment  @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  patient     Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([reminderId, channel, destination])
  @@map("notification_jobs")
}

model Campaign {
  id             String         @id @default(cuid())
  clinicId       String
  name           String
  description    String?
  type           CampaignType
  targetAudience Json?
  channel        Channel
  template       String?
  scheduledAt    DateTime?
  status         CampaignStatus @default(draft)
  sentCount      Int            @default(0)
  createdBy      String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Relations
  clinic  Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  creator User   @relation(fields: [createdBy], references: [id])

  @@map("campaigns")
}

model ClinicSettings {
  id                       String   @id @default(cuid())
  clinicId                 String   @unique
  appointmentBufferMinutes Int      @default(15)
  maxAdvanceBookingDays    Int      @default(90)
  timezone                 String?
  currency                 String   @default("USD")
  workingHours             Json?
  reminderSettings         Json?
  notificationSettings     Json?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  // Relations
  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@map("clinic_settings")
}

model BusinessHours {
  id         String    @id @default(cuid())
  clinicId   String
  dayOfWeek  Int // 0-6, 0=Sunday
  isOpen     Boolean   @default(true)
  openTime   DateTime? // Using DateTime for time, will store as time
  closeTime  DateTime?
  breakStart DateTime?
  breakEnd   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Relations
  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, dayOfWeek])
  @@map("business_hours")
}

model EscalationLog {
  id         String     @id @default(cuid())
  clinicId   String
  entityType EntityType
  entityId   String
  eventType  String
  severity   Severity
  message    String
  metadata   Json?
  userId     String?
  createdAt  DateTime   @default(now())

  // Relations
  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id])

  @@map("escalation_logs")
}
